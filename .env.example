# Optional: set to use PostgreSQL instead of in-memory storage.
# Local example: postgresql://user:password@localhost:5432/coast_experience
# Supabase: use the "Connection string" from Project Settings → Database (URI, not session mode).
# DATABASE_URL=

# Required for admin dashboard login. Use a long random string (e.g. openssl rand -base64 32).
# NEXTAUTH_SECRET=

# Optional: canonical URL in production (e.g. https://your-domain.com). NextAuth uses it for redirects.
# NEXTAUTH_URL=https://your-domain.com

# Optional: used for sitemap, Open Graph, and image URLs.
# NEXT_PUBLIC_SITE_URL=https://your-domain.com

# Optional: hero image on the home page (absolute URL or path under public/).
# NEXT_PUBLIC_HERO_IMAGE_URL=

# Optional: Google Places API (New) key for experience reviews from Google Maps.
# In Google Cloud enable "Places API (New)", create an API key, restrict by HTTP referrer or IP.
# GOOGLE_PLACES_API_KEY=

# Optional: Supabase Storage for media in production (relative paths: media/...).
# In dev, files are served from public/media/. In prod, /api/images/ streams from Supabase.
# Set NEXT_PUBLIC_USE_MEDIA_PROXY=true in production when using Supabase so the client uses the proxy URL.
# NEXT_PUBLIC_SUPABASE_URL=https://xxx.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=
# NEXT_PUBLIC_USE_MEDIA_PROXY=true
