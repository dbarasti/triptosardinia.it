# Optional: set to use PostgreSQL instead of in-memory storage.
# Local example: postgresql://user:password@localhost:5432/coast_experience
# Supabase: use the "Connection string" from Project Settings → Database (URI, not session mode).
# DATABASE_URL=

# Required for admin dashboard login. Use a long random string (e.g. openssl rand -base64 32).
# NEXTAUTH_SECRET=

# Optional: canonical URL in production (e.g. https://your-domain.com). NextAuth uses it for redirects.
# NEXTAUTH_URL=https://your-domain.com

# Optional: used for sitemap and Open Graph URLs.
# NEXT_PUBLIC_SITE_URL=https://your-domain.com

# Optional: Google Places API (New) key for experience reviews from Google Maps.
# In Google Cloud enable "Places API (New)", create an API key, restrict by HTTP referrer or IP.
# GOOGLE_PLACES_API_KEY=
